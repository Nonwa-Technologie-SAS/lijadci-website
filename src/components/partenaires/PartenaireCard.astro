---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import type { Partenaire } from "../../data/partenaires";

interface Props {
	partner: Partenaire;
	imageSrc: ImageMetadata | null;
	/** `grid` : carte centrée, idéale pour plusieurs colonnes (partenaires nationaux) */
	layout?: "row" | "grid";
}

const { partner, imageSrc, layout = "row" } = Astro.props;

const initials =
	partner.name
		.split(/\s+/)
		.filter(Boolean)
		.slice(0, 2)
		.map((w) => w[0]?.toUpperCase() ?? "")
		.join("") || "?";

const isGrid = layout === "grid";
---

<article
	class:list={[
		"h-full rounded-2xl border border-green-900/10 bg-white p-5 ring-1 ring-green-900/5 transition hover:border-green-900/20 hover:shadow-md sm:p-6",
		isGrid && "flex flex-col items-center text-center",
	]}
>
	<div
		class:list={[
			"flex gap-4",
			isGrid ? "w-full flex-col items-center gap-3" : "flex-col sm:flex-row sm:items-start sm:gap-5",
		]}
	>
		<div class:list={["shrink-0", isGrid && "w-full max-w-[200px]"]}>
			{
				imageSrc ? (
					<div
						class:list={[
							"flex items-center justify-center overflow-hidden rounded-xl border border-green-900/10 bg-white",
							isGrid ? "h-28 w-full" : "h-24 w-full sm:h-28 sm:w-40",
						]}
					>
						<Image
							src={imageSrc}
							alt={`Logo — ${partner.name}`}
							class:list={[
								"w-full object-contain p-2",
								isGrid ? "max-h-24" : "max-h-24 sm:max-h-28",
							]}
							width={320}
							height={200}
						/>
					</div>
				) : (
					<div
						class:list={[
							"flex items-center justify-center rounded-xl border border-green-900/15 bg-linear-to-br from-green-50 to-emerald-50 text-2xl font-bold text-green-900",
							isGrid ? "h-28 w-full" : "h-24 w-full sm:h-28 sm:w-40",
						]}
						aria-hidden="true"
					>
						{initials}
					</div>
				)
			}
		</div>
		
	</div>
</article>
