---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import TeamSocialLinks from "./TeamSocialLinks.astro";
import { teamMemberLabel, teams, type TeamMember } from "../../data/teams";
import "swiper/css";

const teamImageModules = import.meta.glob<{ default: ImageMetadata }>(
	"../../assets/images/teams/*.{jpeg,jpg,png,webp}",
	{ eager: true },
);

function resolveTeamImage(file: string | undefined): ImageMetadata | null {
	if (!file) return null;
	const normalized = file.replace(/\\/g, "/");
	const entry = Object.entries(teamImageModules).find(([path]) => {
		const p = path.replace(/\\/g, "/");
		return p.endsWith(`/${normalized}`) || p.endsWith(normalized);
	});
	return entry?.[1].default ?? null;
}

function memberInitials(nom: string): string {
	return (
		nom
			.replace("À compléter", "")
			.split(/\s+/)
			.filter(Boolean)
			.slice(0, 2)
			.map((w) => w[0]?.toUpperCase() ?? "")
			.join("") || "…"
	);
}

function photoAlt(member: TeamMember): string {
	return member.nom.trim() === "À compléter" || member.nom.includes("À compléter")
		? `Photo du poste : ${member.role}`
		: `${member.nom.trim()} — ${member.role}`;
}
---

<div
	class="team-swiper swiper mt-10 -mx-4 px-4 sm:-mx-6 sm:px-6 lg:mx-0 lg:px-0"
	data-slide-count={teams.length}
	aria-roledescription="carrousel"
	aria-label="Membres de l’équipe LIJADCI"
>
	<div class="swiper-wrapper">
		{
			teams.map((member) => {
				const { role, nom, detail, imageFile, socials } = member;
				const photo = resolveTeamImage(imageFile);
				const initials = memberInitials(nom);
				const memberLabel = teamMemberLabel(member);
				return (
					<div class="swiper-slide">
						<article class="flex h-full flex-col rounded-2xl border border-green-900/10 bg-white p-6 text-center shadow-sm">
							<div class="mx-auto h-28 w-28 shrink-0 overflow-hidden rounded-full ring-2 ring-green-900/15 ring-offset-2 ring-offset-white">
								{photo ? (
									<Image
										src={photo}
										alt={photoAlt(member)}
										class="h-full w-full object-cover"
										width={224}
										height={224}
										loading="lazy"
										decoding="async"
									/>
								) : (
									<div
										class="flex h-full w-full items-center justify-center bg-green-900 text-xl font-bold text-white"
										aria-hidden="true"
									>
										{initials}
									</div>
								)}
							</div>
							<h3 class="mt-4 text-sm font-semibold uppercase tracking-wide text-green-800">
								{role}
							</h3>
							<p class="mt-1 text-base font-medium text-green-950">{nom.trim()}</p>
							<p class="mt-3 grow text-left text-sm leading-relaxed text-neutral-600">
								{detail}
							</p>
							<TeamSocialLinks memberLabel={memberLabel} links={socials ?? {}} />
						</article>
					</div>
				);
			})
		}
	</div>
</div>

<script>
	import Swiper from "swiper";
	import { Autoplay, A11y } from "swiper/modules";

	function initTeamSwiper() {
		const el = document.querySelector<HTMLElement>(".team-swiper");
		if (!el || el.dataset.swiperInit === "true") return;

		const slideCount = Number(el.dataset.slideCount ?? "0");
		const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

		new Swiper(el, {
			modules: [Autoplay, A11y],
			slidesPerView: 1,
			spaceBetween: 20,
			speed: 700,
			loop: slideCount > 1,
			allowTouchMove: false,
			simulateTouch: false,
			autoplay: reducedMotion
				? false
				: {
						delay: 3500,
						disableOnInteraction: false,
						pauseOnMouseEnter: false,
					},
			breakpoints: {
				640: { slidesPerView: 2, spaceBetween: 24 },
				1024: { slidesPerView: 3, spaceBetween: 24 },
				1280: { slidesPerView: 4, spaceBetween: 24 },
			},
			a11y: {
				containerMessage: "Carrousel des membres de l’équipe",
			},
		});

		el.dataset.swiperInit = "true";
	}

	initTeamSwiper();
	document.addEventListener("astro:page-load", initTeamSwiper);
</script>

<style>
	.team-swiper .swiper-slide {
		height: auto;
	}
</style>
