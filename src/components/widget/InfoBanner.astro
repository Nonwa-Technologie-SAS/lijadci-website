---
/**
 * Bande d’annonces sous le header — modifiez `messages` pour diffuser vos infos.
 * Chaque entrée peut avoir un lien optionnel.
 */
const messages = [
	{
		text: "Forum citoyen le 17 mai 2026 à Abidjan — co-construction des priorités.",
		href: "/evenements",
	},
	{
		text: "Rejoignez le mouvement : adhésion et groupes de travail ouverts à toutes et tous.",
		href: "/adhesion",
	},
	{
		text: "Actualités et retours de terrain : suivez les initiatives LIJADCI.",
		href: "/actualites",
	},
] as const;
---

<aside
	class="info-banner border-b border-amber-800/30 bg-linear-to-r from-amber-300 via-amber-100 to-yellow-600 text-green-950 shadow-sm"
	aria-label="Annonces et informations"
>
	<div class="relative overflow-hidden py-2.5">
		<div
			class="info-banner-icon pointer-events-none absolute left-3 top-1/2 z-10 hidden -translate-y-1/2 sm:block"
			aria-hidden="true"
		>
			<svg
				class="h-4 w-4 text-green-900/85"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				viewBox="0 0 24 24"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"
				/>
			</svg>
		</div>

		<div class="info-banner-viewport overflow-hidden pl-0 sm:pl-10">
			<div class="info-banner-track flex w-max">
				<ul class="info-banner-list flex shrink-0 items-center" role="list">
					{
						messages.map(({ text, href }, i) => (
							<li class="flex shrink-0 items-center">
								{i > 0 && (
									<span
										class="mx-6 select-none text-green-900/45 sm:mx-10"
										aria-hidden="true"
									>
										·
									</span>
								)}
								{href ? (
									<a
										href={href}
										class="shrink-0 whitespace-nowrap text-sm font-semibold text-green-950 underline decoration-green-950/45 underline-offset-2 transition hover:decoration-green-900"
									>
										{text}
									</a>
								) : (
									<span class="shrink-0 whitespace-nowrap text-sm font-medium text-green-950">
										{text}
									</span>
								)}
							</li>
						))
					}
				</ul>
				<ul
					class="info-banner-list flex shrink-0 items-center"
					role="presentation"
					aria-hidden="true"
				>
					{
						messages.map(({ text, href }, i) => (
							<li class="flex shrink-0 items-center">
								{i > 0 && (
									<span
										class="mx-6 select-none text-green-900/45 sm:mx-10"
										aria-hidden="true"
									>
										·
									</span>
								)}
								{href ? (
									<a
										href={href}
										tabindex="-1"
										class="shrink-0 whitespace-nowrap text-sm font-semibold text-green-950 underline decoration-green-950/45 underline-offset-2"
									>
										{text}
									</a>
								) : (
									<span class="shrink-0 whitespace-nowrap text-sm font-medium text-green-950">
										{text}
									</span>
								)}
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</div>
</aside>

<style>
	@keyframes info-banner-marquee {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-50%);
		}
	}

	.info-banner-track {
		animation: info-banner-marquee 45s linear infinite;
	}

	.info-banner:hover .info-banner-track {
		animation-play-state: paused;
	}

	@media (prefers-reduced-motion: reduce) {
		.info-banner-viewport {
			overflow-x: auto;
			-webkit-overflow-scrolling: touch;
		}

		.info-banner-track {
			animation: none;
			width: 100% !important;
			max-width: 100%;
		}

		.info-banner-list:last-child {
			display: none;
		}

		.info-banner-list {
			flex-wrap: wrap;
			width: 100%;
			justify-content: center;
			row-gap: 0.35rem;
			column-gap: 0;
		}
	}
</style>
