---
import type { Actualite } from "../../data/actualites";

interface Props {
	article: Actualite;
}

const { article } = Astro.props;
---

<li>
	<article
		class="flex flex-col gap-6 rounded-2xl border border-green-900/10 bg-white p-6 shadow-sm transition hover:border-green-900/20 hover:shadow-md sm:flex-row sm:items-stretch sm:gap-8 sm:p-8"
	>
		<div
			class="flex shrink-0 flex-col justify-center rounded-xl bg-green-900 px-5 py-4 text-center text-white sm:w-36"
		>
			<time
				class="text-xs font-semibold uppercase tracking-wide text-green-200"
				datetime={article.dateIso}
			>
				{article.dateLabel}
			</time>
			<span class="mt-2 text-sm font-medium text-green-100">
				{article.category}
			</span>
		</div>
		<div class="min-w-0 flex-1">
			<h2 class="text-xl font-bold text-green-950 sm:text-2xl">
				<a
					href={`/actualites/${article.slug}`}
					class="rounded-md outline-none hover:text-green-800 focus-visible:ring-2 focus-visible:ring-green-900"
				>
					{article.title}
				</a>
			</h2>
			<p class="mt-3 text-base leading-relaxed text-neutral-600">
				{article.excerpt}
			</p>
			<a
				href={`/actualites/${article.slug}`}
				class="mt-4 inline-flex text-sm font-semibold text-green-800 underline decoration-green-800/30 underline-offset-4 hover:decoration-green-800"
			>
				Lire l’article →
			</a>
		</div>
	</article>
</li>
