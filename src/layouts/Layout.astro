---
import { Font } from "astro:assets";
import Footer from '../components/widget/Footer.astro';
import Header from '../components/widget/Header.astro';
import InfoBanner from '../components/widget/InfoBanner.astro';
import TopHeader from '../components/widget/TopHeader.astro';
import "../styles/global.css";
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>LIJADCI</title>
		<Font cssVariable="--font-open-sans" />
	</head>
	<body>
		<TopHeader/>
		<Header/>
		<InfoBanner />
		<slot />
		<Footer/>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: var(--font-open-sans);
	}
</style>
