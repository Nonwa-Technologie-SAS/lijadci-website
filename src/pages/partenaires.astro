---
import type { ImageMetadata } from "astro";
import PartenaireCard from "../components/partenaires/PartenaireCard.astro";
import {
detailNational,
partenairesParCategorie,
type Partenaire,
} from "../data/partenaires";
import Layout from "../layouts/Layout.astro";

const partnerImageModules = import.meta.glob<{ default: ImageMetadata }>(
	"../assets/images/partners/*.{jpeg,jpg,png,webp}",
	{ eager: true },
);

/** Partenaires nationaux = tous les fichiers du dossier images/partners (tri stables par nom de fichier) */
const nationauxAvecImage = Object.entries(partnerImageModules)
	.map(([path, mod]) => {
		const segments = path.replace(/\\/g, "/").split("/");
		const filename = segments[segments.length - 1] ?? path;
		const d = detailNational(filename);
		const partner: Partenaire = {
			id: `national-${filename}`,
			name: d.name,
			description: d.description,
			href: d.href,
			categorie: "national",
		};
		return { filename, partner, imageSrc: mod.default };
	})
	.sort((a, b) => a.filename.localeCompare(b.filename, "fr"));

function resolvePartnerImage(file: string | undefined): ImageMetadata | null {
	if (!file) return null;
	const normalized = file.replace(/\\/g, "/");
	const entry = Object.entries(partnerImageModules).find(([path]) => {
		const p = path.replace(/\\/g, "/");
		return p.endsWith(`/${normalized}`) || p.endsWith(normalized);
	});
	return entry?.[1].default ?? null;
}

const internationaux = partenairesParCategorie("international");
const sponsors = partenairesParCategorie("sponsor");
---

<Layout>
	<main class="bg-neutral-50 text-neutral-900">
		<div
			class="relative overflow-hidden border-b border-green-900/10 bg-linear-to-br from-green-900 via-green-800 to-emerald-950 px-4 py-14 text-white sm:px-6 lg:px-8"
		>
			<div
				class="pointer-events-none absolute -right-16 top-10 h-56 w-56 rounded-full bg-orange-400/20 blur-3xl"
				aria-hidden="true"
			>
			</div>
			<div class="relative mx-auto max-w-7xl">
				<p class="text-sm font-medium uppercase tracking-widest text-green-200/90">
					Coopérations
				</p>
				<h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
					Partenaires
				</h1>
				<p class="mt-4 max-w-2xl text-base text-green-100/95 sm:text-lg">
					Institutions, associations, entreprises et organismes internationaux : nos
					partenaires amplifient l’impact des actions menées avec la jeunesse
					ivoirienne.
				</p>
			</div>
		</div>

		<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
			<section class="max-w-3xl" aria-labelledby="partenaires-intro">
				<h2 id="partenaires-intro" class="sr-only">Introduction</h2>
				<p class="text-lg font-medium text-green-950">
					La diversité de nos alliances reflète notre volonté d’ouverture : partenaires
					nationaux, acteurs internationaux et soutiens financiers ou logistiques
					travaillent aux côtés de LIJADCI.
				</p>
				<p class="mt-4 text-base leading-relaxed text-neutral-700">
					Les partenaires nationaux sont présentés à partir des logos du dossier dédié
					(images des structures basées en Côte d’Ivoire). Les textes pourront être
					actualisés au fil des conventions et des communications officielles.
				</p>
			</section>

			<section class="mt-16" aria-labelledby="section-national">
				<h2
					id="section-national"
					class="text-2xl font-bold tracking-tight text-green-950 sm:text-3xl"
				>
					Partenaires nationaux
				</h2>
				<p class="mt-2 text-neutral-600">
					Logos des structures ivoiriennes présentes dans le dossier des partenaires
					nationaux (un fichier image = un partenaire).
				</p>
				{
					nationauxAvecImage.length === 0 ? (
						<p class="mt-8 rounded-2xl border border-green-900/10 bg-white p-8 text-center text-neutral-600">
							Aucun logo national pour le moment. Ajoutez des images (JPEG, PNG ou WebP)
							dans le dossier des partenaires du projet pour les afficher ici.
						</p>
					) : (
						<ul class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
							{nationauxAvecImage.map(({ partner, imageSrc }) => (
								<li class="h-full min-w-0">
									<PartenaireCard partner={partner} imageSrc={imageSrc} layout="grid" />
								</li>
							))}
						</ul>
					)
				}
			</section>

			<!-- <section class="mt-16 lg:mt-20" aria-labelledby="section-international">
				<h2
					id="section-international"
					class="text-2xl font-bold tracking-tight text-green-950 sm:text-3xl"
				>
					Partenaires internationaux
				</h2>
				<p class="mt-2 text-neutral-600">
					ONG, réseaux régionaux et institutions hors Côte d’Ivoire.
				</p>
				<ul class="mt-8 grid gap-6 lg:grid-cols-1">
					{
						internationaux.map((p) => (
							<li>
								<PartenaireCard partner={p} imageSrc={resolvePartnerImage(p.imageFile)} />
							</li>
						))
					}
				</ul>
			</section> -->

			<!-- <section class="mt-16 lg:mt-20" aria-labelledby="section-sponsors">
				<h2
					id="section-sponsors"
					class="text-2xl font-bold tracking-tight text-green-950 sm:text-3xl"
				>
					Sponsors & soutiens
				</h2>
				<p class="mt-2 text-neutral-600">
					Mécénat, visibilité et appuis ponctuels pour nos temps forts.
				</p>
				<ul class="mt-8 grid gap-6 lg:grid-cols-1">
					{
						sponsors.map((p) => (
							<li>
								<PartenaireCard partner={p} imageSrc={resolvePartnerImage(p.imageFile)} />
							</li>
						))
					}
				</ul>
			</section> -->

			<section
				class="mt-16 flex flex-col items-start justify-between gap-6 rounded-2xl bg-linear-to-r from-green-900 to-emerald-900 px-6 py-8 text-white sm:flex-row sm:items-center sm:px-10 lg:mt-20"
				aria-labelledby="partenaires-cta"
			>
				<div>
					<h2 id="partenaires-cta" class="text-xl font-bold sm:text-2xl">
						Devenir partenaire
					</h2>
					<p class="mt-2 max-w-xl text-sm text-green-100 sm:text-base">
						Proposez une coopération technique, financière ou en visibilité : notre
						équipe étudie chaque demande.
					</p>
				</div>
				<div class="flex flex-wrap gap-3">
					<a
						href="/contact"
						class="inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-semibold text-green-900 shadow-sm transition hover:bg-green-50"
					>
						Nous contacter
					</a>
					<a
						href="/actions"
						class="inline-flex items-center justify-center rounded-xl border border-white/40 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
					>
						Nos actions
					</a>
				</div>
			</section>
		</div>
	</main>
</Layout>
