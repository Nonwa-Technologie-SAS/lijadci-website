---
import Layout from "../layouts/Layout.astro";

/** Textes et chiffres — à personnaliser. */
const slogan =
	"Unis pour l’action, engagés pour l’avenir de nos communautés.";

const presentation = {
	lead:
		"LIJADCI rassemble citoyennes et citoyens, associations et acteurs du territoire autour d’initiatives concrètes : solidarité, formation, développement durable et participation citoyenne.",
	paragraphs: [
		"Notre mouvement vise à renforcer le lien social, à soutenir les projets locaux et à offrir des espaces d’apprentissage accessibles à toutes et tous.",
		"Que vous souhaitiez vous engager au quotidien, soutenir nos actions ou co-construire des partenariats durables, vous avez une place parmi nous.",
	],
};

const stats = [
	{ value: "1 200+", label: "Membres actifs", hint: "Réseau en croissance" },
	{ value: "48", label: "Projets réalisés", hint: "Territoires accompagnés" },
	{ value: "32", label: "Formations organisées", hint: "Sessions depuis 2022" },
] as const;

const ctas = [
	{
		title: "Rejoindre le mouvement",
		description:
			"Adhérez, participez aux groupes de travail et faites entendre votre voix.",
		href: "/adhesion",
		label: "Je m’engage",
		variant: "primary" as const,
	},
	{
		title: "Faire un don",
		description:
			"Soutenez nos projets et la mise en œuvre de nos actions sur le terrain.",
		href: "/contact",
		label: "Contacter pour un don",
		variant: "secondary" as const,
	},
	{
		title: "Devenir partenaire",
		description:
			"Entreprises, institutions ou associations : co-construisons des programmes durables.",
		href: "/partenaires",
		label: "Proposer un partenariat",
		variant: "outline" as const,
	},
] as const;

const actualites = [
	{
		date: "28 avril 2026",
		dateIso: "2026-04-28",
		title: "Lancement de la campagne de sensibilisation locale",
		excerpt:
			"Retour sur les premiers ateliers et la mobilisation des bénévoles dans les quartiers partenaires.",
		href: "/actualites/campagne-sensibilisation-locale",
	},
	{
		date: "15 avril 2026",
		dateIso: "2026-04-15",
		title: "Partenariat renforcé avec les acteurs éducatifs",
		excerpt:
			"Signature de conventions et nouvelles sessions de formation pour les encadrant·es.",
		href: "/actualites/partenariat-acteurs-educatifs",
	},
	{
		date: "2 avril 2026",
		dateIso: "2026-04-02",
		title: "Bilan trimestriel des projets solidaires",
		excerpt:
			"Perspectives pour le prochain semestre au sein du mouvement, à partir des retours des équipes et des bénévoles.",
		href: "/actualites/bilan-projets-solidaires",
	},
] as const;

const evenements = [
	{
		day: "17",
		month: "mai",
		year: "2026",
		dateIso: "2026-05-17",
		title: "Forum citoyen — co-construction des priorités 2026",
		meta: "Abidjan • 9h00 – 13h00",
		href: "/evenements",
	},
	{
		day: "24",
		month: "mai",
		year: "2026",
		dateIso: "2026-05-24",
		title: "Atelier de formation — mobilisation communautaire",
		meta: "Hybride • inscription ouverte",
		href: "/evenements",
	},
	{
		day: "7",
		month: "juin",
		year: "2026",
		dateIso: "2026-06-07",
		title: "Journée solidarité & stands associatifs",
		meta: "Parc des expositions • entrée libre",
		href: "/evenements",
	},
] as const;
---

<Layout>
	<main class="bg-neutral-50 text-neutral-900">
		<!-- Bannière principale -->
		<section
			class="relative overflow-hidden bg-linear-to-br from-green-950 via-green-900 to-emerald-900 px-4 pb-20 pt-16 text-white sm:px-6 sm:pb-24 sm:pt-20 lg:px-8 lg:pb-28 lg:pt-24"
			aria-labelledby="hero-heading"
		>
			<div
				class="pointer-events-none absolute -left-32 top-20 h-72 w-72 rounded-full bg-lime-400/15 blur-3xl"
				aria-hidden="true"
			>
			</div>
			<div
				class="pointer-events-none absolute -right-24 bottom-10 h-80 w-80 rounded-full bg-emerald-300/10 blur-3xl"
				aria-hidden="true"
			>
			</div>
			<div class="relative mx-auto max-w-7xl">
				<p
					class="text-xs font-semibold uppercase tracking-[0.2em] text-green-200/90 sm:text-sm"
				>
					LIJADCI
				</p>
				<h1
					id="hero-heading"
					class="mt-3 max-w-4xl text-3xl font-bold leading-tight tracking-tight sm:text-4xl lg:text-5xl xl:text-6xl"
				>
					Agir ensemble pour des territoires plus solidaires
				</h1>
				<p
					class="mt-6 max-w-2xl text-base leading-relaxed text-green-100/95 sm:text-lg"
				>
					Bénévolat, projets, formations et plaidoyer : rejoignez un mouvement
					ancré sur le terrain et tourné vers l’impact.
				</p>
				<div
					class="mt-10 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center"
				>
					<a
						href="/adhesion"
						class="inline-flex items-center justify-center rounded-xl bg-white px-6 py-3.5 text-sm font-semibold text-green-900 shadow-lg shadow-green-950/20 transition hover:bg-green-50 focus-visible:outline focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-green-900"
					>
						Rejoindre le mouvement
					</a>
					<a
						href="/about"
						class="inline-flex items-center justify-center rounded-xl border border-white/40 bg-white/5 px-6 py-3.5 text-sm font-semibold text-white backdrop-blur-sm transition hover:bg-white/10 focus-visible:outline focus-visible:ring-2 focus-visible:ring-white/80"
					>
						Découvrir nos valeurs
					</a>
				</div>
			</div>
		</section>

		<!-- Slogan -->
		<section
			class="border-b border-green-900/10 bg-white px-4 py-12 sm:px-6 lg:px-8"
			aria-labelledby="slogan-heading"
		>
			<div class="mx-auto max-w-4xl text-center">
				<h2 id="slogan-heading" class="sr-only">Slogan du mouvement</h2>
				<p
					class="text-xl font-medium leading-relaxed text-green-900 sm:text-2xl lg:text-3xl"
				>
					<span class="text-green-700" aria-hidden="true">«</span>
					{slogan}
					<span class="text-green-700" aria-hidden="true">»</span>
				</p>
			</div>
		</section>

		<!-- Présentation rapide -->
		<section
			class="px-4 py-14 sm:px-6 lg:px-8 lg:py-20"
			aria-labelledby="intro-heading"
		>
			<div class="mx-auto max-w-7xl">
				<h2
					id="intro-heading"
					class="text-2xl font-bold tracking-tight text-green-950 sm:text-3xl"
				>
					Qui sommes-nous ?
				</h2>
				<p class="mt-3 max-w-3xl text-lg text-neutral-600">
					{presentation.lead}
				</p>
				<div
					class="mt-10 grid gap-8 lg:grid-cols-2 lg:gap-12 lg:items-start"
				>
					{
						presentation.paragraphs.map((text) => (
							<p class="text-base leading-relaxed text-neutral-700">{text}</p>
						))
					}
				</div>
			</div>
		</section>

		<!-- Appels à l’action -->
		<section
			class="border-y border-green-900/10 bg-white px-4 py-14 sm:px-6 lg:px-8 lg:py-16"
			aria-labelledby="cta-heading"
		>
			<div class="mx-auto max-w-7xl">
				<h2
					id="cta-heading"
					class="text-2xl font-bold tracking-tight text-green-950 sm:text-3xl"
				>
					Agir avec nous
				</h2>
				<p class="mt-2 max-w-2xl text-neutral-600">
					Choisissez la formule d’engagement qui vous correspond.
				</p>
				<ul
					class="mt-10 grid gap-6 md:grid-cols-3"
				>
					{
						ctas.map(({ title, description, href, label, variant }) => (
							<li>
								<article
									class:list={[
										"flex h-full flex-col rounded-2xl border p-6 shadow-sm transition",
										variant === "primary" &&
											"border-green-900/20 bg-linear-to-br from-green-50 to-white ring-1 ring-green-900/10",
										variant === "secondary" &&
											"border-green-900/15 bg-neutral-50/80",
										variant === "outline" &&
											"border-green-900/10 bg-white hover:border-green-900/25",
									]}
								>
									<h3 class="text-lg font-semibold text-green-950">{title}</h3>
									<p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-600">
										{description}
									</p>
									<a
										href={href}
										class:list={[
											"mt-6 inline-flex items-center justify-center rounded-xl px-4 py-3 text-sm font-semibold transition focus-visible:outline focus-visible:ring-2 focus-visible:ring-green-900 focus-visible:ring-offset-2",
											variant === "primary" &&
												"bg-green-900 text-white hover:bg-green-800",
											variant === "secondary" &&
												"bg-amber-100 text-green-950 hover:bg-amber-200",
											variant === "outline" &&
												"border border-green-900/25 bg-white text-green-900 hover:bg-green-50",
										]}
									>
										{label}
									</a>
								</article>
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<!-- Statistiques -->
		<section
			class="bg-linear-to-b from-green-900 to-green-950 px-4 py-14 text-white sm:px-6 lg:px-8 lg:py-16"
			aria-labelledby="stats-heading"
		>
			<div class="mx-auto max-w-7xl">
				<h2 id="stats-heading" class="sr-only">Chiffres clés</h2>
				<ul
					class="grid gap-10 sm:grid-cols-3 sm:gap-8"
				>
					{
						stats.map(({ value, label, hint }) => (
							<li class="text-center sm:text-left">
								<p class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
									{value}
								</p>
								<p class="mt-2 text-base font-semibold text-green-100">{label}</p>
								<p class="mt-1 text-sm text-green-200/80">{hint}</p>
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<!-- Actualités récentes -->
		<section
			class="px-4 py-14 sm:px-6 lg:px-8 lg:py-20"
			aria-labelledby="news-heading"
		>
			<div class="mx-auto max-w-7xl">
				<div
					class="flex flex-col justify-between gap-4 sm:flex-row sm:items-end"
				>
					<div>
						<h2
							id="news-heading"
							class="text-2xl font-bold tracking-tight text-green-950 sm:text-3xl"
						>
							Actualités récentes
						</h2>
						<p class="mt-2 text-neutral-600">
							Infos, retours de terrain et annonces du mouvement.
						</p>
					</div>
					<a
						href="/actualites"
						class="inline-flex shrink-0 items-center gap-1 text-sm font-semibold text-green-800 underline decoration-green-800/30 underline-offset-4 hover:decoration-green-800"
					>
						Toutes les actualités
						<span aria-hidden="true">→</span>
					</a>
				</div>
				<ul class="mt-10 grid gap-6 lg:grid-cols-3">
					{
						actualites.map(({ date, dateIso, title, excerpt, href }) => (
							<li>
								<article class="flex h-full flex-col rounded-2xl border border-green-900/10 bg-white p-6 shadow-sm transition hover:border-green-900/20 hover:shadow-md">
									<time
										class="text-xs font-medium uppercase tracking-wide text-green-700"
										datetime={dateIso}
									>
										{date}
									</time>
									<h3 class="mt-3 text-lg font-semibold text-green-950">
										<a
											href={href}
											class="rounded-md outline-none focus-visible:ring-2 focus-visible:ring-green-900"
										>
											{title}
										</a>
									</h3>
									<p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-600">
										{excerpt}
									</p>
									<a
										href={href}
										class="mt-4 inline-flex text-sm font-semibold text-green-800"
									>
										Lire la suite
									</a>
								</article>
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<!-- Événements à venir -->
		<section
			class="relative overflow-hidden border-t border-green-900/10 bg-linear-to-b from-emerald-50/40 via-white to-neutral-50/80 px-4 py-16 sm:px-6 lg:px-8 lg:py-24"
			aria-labelledby="events-heading"
		>
			<div
				class="pointer-events-none absolute -right-20 top-1/2 h-64 w-64 -translate-y-1/2 rounded-full bg-green-200/25 blur-3xl"
				aria-hidden="true"
			>
			</div>
			<div
				class="pointer-events-none absolute -left-16 bottom-0 h-48 w-48 rounded-full bg-emerald-300/20 blur-3xl"
				aria-hidden="true"
			>
			</div>

			<div class="relative mx-auto max-w-7xl">
				<div
					class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between"
				>
					<div class="max-w-2xl">
						<p
							class="text-xs font-semibold uppercase tracking-[0.2em] text-green-800/80"
						>
							Agenda
						</p>
						<h2
							id="events-heading"
							class="mt-2 text-2xl font-bold tracking-tight text-green-950 sm:text-3xl lg:text-4xl"
						>
							Événements à venir
						</h2>
						<p class="mt-3 text-base leading-relaxed text-neutral-600 sm:text-lg">
							Retrouvez nos prochains temps forts : forums, formations et
							rencontres ouvertes à toutes et tous.
						</p>
					</div>
					<a
						href="/evenements"
						class="inline-flex w-fit items-center gap-2 rounded-full border border-green-900/20 bg-white px-5 py-2.5 text-sm font-semibold text-green-900 shadow-sm transition hover:border-green-900/35 hover:bg-green-50 focus-visible:outline focus-visible:ring-2 focus-visible:ring-green-900 focus-visible:ring-offset-2"
					>
						Tout l’agenda
						<svg
							class="h-4 w-4"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							viewBox="0 0 24 24"
							aria-hidden="true"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
							/>
						</svg>
					</a>
				</div>

				<ul
					class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-8"
				>
					{
						evenements.map(({ day, month, year, dateIso, title, meta, href }) => (
							<li class="h-full">
								<article
									class="group flex h-full flex-col overflow-hidden rounded-2xl border border-green-900/10 bg-white shadow-sm ring-1 ring-black/4 transition hover:-translate-y-0.5 hover:border-green-900/20 hover:shadow-lg hover:shadow-green-900/10"
								>
									<div
										class="relative bg-linear-to-br from-green-900 via-green-800 to-emerald-900 px-5 py-4 text-white"
									>
										<div
											class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-white/10 blur-2xl"
											aria-hidden="true"
										>
										</div>
										<time
											class="relative flex items-baseline gap-2"
											datetime={dateIso}
										>
											<span class="text-3xl font-bold tabular-nums leading-none">
												{day}
											</span>
											<span class="flex flex-col text-left leading-tight">
												<span class="text-sm font-semibold capitalize text-green-100">
													{month}
												</span>
												<span class="text-xs font-medium text-green-200/90">
													{year}
												</span>
											</span>
										</time>
									</div>
									<div class="flex flex-1 flex-col p-5 sm:p-6">
										<h3 class="text-lg font-semibold leading-snug text-green-950">
											<a
												href={href}
												class="rounded-md outline-none transition group-hover:text-green-800 focus-visible:ring-2 focus-visible:ring-green-900"
											>
												{title}
											</a>
										</h3>
										<p
											class="mt-3 flex items-start gap-2 text-sm leading-relaxed text-neutral-600"
										>
											<svg
												class="mt-0.5 h-4 w-4 shrink-0 text-green-700/80"
												fill="none"
												stroke="currentColor"
												stroke-width="1.75"
												viewBox="0 0 24 24"
												aria-hidden="true"
											>
												<path
													stroke-linecap="round"
													stroke-linejoin="round"
													d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5a2.25 2.25 0 002.25-2.25m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5a2.25 2.25 0 012.25 2.25v7.5"
												/>
											</svg>
											<span>{meta}</span>
										</p>
										<div class="mt-auto border-t border-neutral-100 pt-4">
											<a
												href={href}
												class="inline-flex items-center gap-1 text-sm font-semibold text-green-800 transition group-hover:gap-2"
											>
												En savoir plus
												<span aria-hidden="true">→</span>
											</a>
										</div>
									</div>
								</article>
							</li>
						))
					}
				</ul>
			</div>
		</section>
	</main>
</Layout>
