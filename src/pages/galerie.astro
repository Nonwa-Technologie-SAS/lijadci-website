---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";

const galleryModules = import.meta.glob<{ default: ImageMetadata }>(
	"../assets/images/galerie/*.{jpeg,jpg,png,webp}",
	{ eager: true },
);

const images = Object.entries(galleryModules)
	.map(([path, mod]) => {
		const segments = path.replace(/\\/g, "/").split("/");
		const filename = segments[segments.length - 1] ?? path;
		return {
			path,
			filename,
			src: mod.default,
		};
	})
	.sort((a, b) => a.filename.localeCompare(b.filename, "fr"));
---

<Layout>
	<main class="bg-neutral-50 text-neutral-900">
		<div
			class="relative overflow-hidden border-b border-green-900/10 bg-linear-to-br from-green-900 via-green-800 to-emerald-950 px-4 py-14 text-white sm:px-6 lg:px-8"
		>
			<div
				class="pointer-events-none absolute -right-16 bottom-0 h-64 w-64 rounded-full bg-orange-400/15 blur-3xl"
				aria-hidden="true"
			>
			</div>
			<div class="relative mx-auto max-w-7xl">
				<p class="text-sm font-medium uppercase tracking-widest text-green-200/90">
					En images
				</p>
				<h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
					Galerie
				</h1>
				<p class="mt-4 max-w-2xl text-base text-green-100/95 sm:text-lg">
					Photos et visuels de terrain : événements, rencontres et actions du mouvement.
					Les contenus vidéo pourront compléter cet espace (liens ou intégrations).
				</p>
			</div>
		</div>

		<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
			<section class="max-w-3xl" aria-labelledby="gal-intro">
				<h2 id="gal-intro" class="sr-only">Introduction</h2>
				<p class="text-lg font-medium text-green-950">
					Un aperçu visuel des initiatives portées par LIJADCI et ses partenaires sur
					le territoire.
				</p>
				<p class="mt-4 text-base leading-relaxed text-neutral-700">
					Ajoutez vos fichiers image dans le dossier dédié du projet pour qu’ils
					apparaissent automatiquement dans la grille ci-dessous.
				</p>
			</section>

			{
				images.length === 0 ? (
					<div class="mt-12 rounded-2xl border border-dashed border-green-900/25 bg-white/80 p-12 text-center">
						<p class="text-neutral-600">
							Aucune image pour le moment. Placez des photos (JPEG, PNG ou WebP) dans le
							dossier <strong class="text-green-950">src/assets/images/galerie/</strong>{" "}
							puis relancez le build.
						</p>
						<a
							href="/evenements"
							class="mt-6 inline-flex rounded-xl bg-green-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-green-800"
						>
							Voir les événements
						</a>
					</div>
				) : (
					<ul
						class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
						aria-label="Galerie photos"
					>
						{images.map(({ filename, src }) => (
							<li class="group overflow-hidden rounded-2xl border border-green-900/10 bg-white shadow-sm ring-1 ring-green-900/5 transition hover:border-green-900/20 hover:shadow-md">
								<figure class="m-0">
									<div class="aspect-4/3 w-full overflow-hidden bg-neutral-100">
										<Image
											src={src}
											alt={`Galerie LIJADCI — ${filename.replace(/\.[^.]+$/, "").replace(/[-_]/g, " ")}`}
											class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
											width={800}
											height={600}
											loading="lazy"
											decoding="async"
										/>
									</div>
									<figcaption class="sr-only">{filename}</figcaption>
								</figure>
							</li>
						))}
					</ul>
				)
			}

			<section
				class="mt-16 rounded-2xl border border-green-900/10 bg-white p-6 shadow-sm sm:p-8"
				aria-labelledby="gal-video"
			>
				<h2 id="gal-video" class="text-lg font-semibold text-green-950">
					Vidéos
				</h2>
				<p class="mt-2 text-sm leading-relaxed text-neutral-600">
					Les intégrations (YouTube, Vimeo, etc.) ou fichiers hébergés pourront être
					ajoutées ici lorsque les contenus seront validés — évitez d’héberger de
					lourdes vidéos directement dans le dépôt sans optimisation.
				</p>
			</section>
		</div>
	</main>
</Layout>
