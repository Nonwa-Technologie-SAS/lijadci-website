---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import TeamSocialLinks from "../components/equipe/TeamSocialLinks.astro";
import Layout from "../layouts/Layout.astro";

const teamImageModules = import.meta.glob<{ default: ImageMetadata }>(
	"../assets/images/teams/*.{jpeg,jpg,png,webp}",
	{ eager: true },
);

function resolveTeamImage(file: string | undefined): ImageMetadata | null {
	if (!file) return null;
	const normalized = file.replace(/\\/g, "/");
	const entry = Object.entries(teamImageModules).find(([path]) => {
		const p = path.replace(/\\/g, "/");
		return p.endsWith(`/${normalized}`) || p.endsWith(normalized);
	});
	return entry?.[1].default ?? null;
}

/**
 * Contenu générique / placeholders — à remplacer par les textes validés
 * (ne pas publier de missions ou chiffres « officiels » sans source).
 */
const histoire = {
	title: "Notre histoire",
	paragraphs: [
		"LIJADCI est né du constat que les jeunes ivoirien·nes disposent d’une énergie, d’idées et d’initiatives qui méritent d’être structurées, visibles et soutenues sur tout le territoire.",
		"À partir de rencontres entre associations, étudiant·es et acteurs du développement local, le mouvement s’est donné pour ambition de créer des espaces de formation, de dialogue et d’action collective autour des enjeux politiques, économiques, sociaux et environnementaux.",
		"Aujourd’hui, LIJADCI poursuit ce chemin en s’appuyant sur des bénévoles, des partenaires et des communautés engagées — avec la volonté de rester ancré sur le terrain et ouvert au grand public.",
	],
};

const mission = {
	title: "Mission",
	text: "Mobiliser et accompagner la jeunesse ivoirienne pour renforcer les capacités citoyennes, promouvoir l’entrepreneuriat et l’insertion, défendre les droits humains et la démocratie, et contribuer à une cohésion sociale durable — par la formation, le plaidoyer et des projets concrets.",
};

const vision = {
	title: "Vision",
	text: "Une société ivoirienne où chaque jeune peut s’exprimer, se former, entreprendre et participer pleinement à la vie publique, dans le respect de la diversité et du développement durable.",
};

const valeurs = [
	{
		title: "Citéyenneté & démocratie",
		text: "Participation, transparence et respect des droits fondamentaux au cœur de nos actions.",
	},
	{
		title: "Inclusion & diversité",
		text: "Accueil de tous les profils, lutte contre les discriminations, priorité aux voix souvent marginalisées.",
	},
	{
		title: "Formation & innovation",
		text: "Montée en compétences, esprit critique et adaptation aux enjeux contemporains.",
	},
	{
		title: "Solidarité & cohésion",
		text: "Travail collectif, entraide entre territoires et générations.",
	},
	{
		title: "Intégrité & responsabilité",
		text: "Exemplarité dans la gestion des projets et la relation aux partenaires.",
	},
	{
		title: "Développement durable",
		text: "Prise en compte des impacts sociaux et environnementaux de nos initiatives.",
	},
] as const;

/**
 * Rôles indicatifs — noms, photos et socials : à compléter par l’équipe.
 * Photos : fichiers dans src/assets/images/teams/ (voir imageFile).
 * Réseaux : clés optionnelles facebook, linkedin, instagram, youtube, whatsapp (URLs des profils).
 */
const equipe = [
	{
		role: "Coordination générale",
		nom: "À compléter",
		detail:
			"Pilotage stratégique",
		imageFile: "pexels-sujasen-20181989.jpg",
		socials: {
			linkedin: "https://www.linkedin.com/in/…",
			facebook: "https://www.facebook.com/…",
			instagram: "https://www.instagram.com/…",
			youtube: "https://www.youtube.com/@…",
			whatsapp: "https://wa.me/225XXXXXXXX",
		},
	},
	{
		role: "Pôle formation & insertion",
		nom: "À compléter",
		detail:
			"Ateliers, programmes de montée.",
		imageFile: "pexels-anurag-sharma-2258727-31296961.jpg",
		socials: {
			linkedin: "https://www.linkedin.com/in/…",
			facebook: "https://www.facebook.com/…",
			instagram: "https://www.instagram.com/…",
			youtube: "https://www.youtube.com/@…",
			whatsapp: "https://wa.me/225XXXXXXXX",
		},
	},
	{
		role: "Pôle plaidoyer & droits humains",
		nom: "À compléter",
		detail:
			"Campagnes de sensibilisation",
		imageFile: "pexels-sujasen-20181989.jpg",
		socials: {
			linkedin: "https://www.linkedin.com/in/…",
			facebook: "https://www.facebook.com/…",
			instagram: "https://www.instagram.com/…",
			youtube: "https://www.youtube.com/@…",
			whatsapp: "https://wa.me/225XXXXXXXX",
		},
	},
	{
		role: "Pôle communication & mobilisation",
		nom: "À compléter",
		detail:
			"Contenus, réseaux sociaux",
		imageFile: "pexels-anurag-sharma-2258727-31296961.jpg",
		socials: {
			linkedin: "https://www.linkedin.com/in/…",
			facebook: "https://www.facebook.com/…",
			instagram: "https://www.instagram.com/…",
			youtube: "https://www.youtube.com/@…",
			whatsapp: "https://wa.me/225XXXXXXXX",
		},
	},
] as const;

const organigramme = {
	intro:
		"Schéma indicatif de la gouvernance : les intitulés peuvent être ajustés selon vos statuts et votre fonctionnement effectif.",
	niveaux: [
		{
			label: "Instance de référence",
			nom: "Assemblée / instance souveraine (à préciser)",
			enfants: [
				{
					label: "Coordination",
					nom: "Équipe de coordination",
					enfants: [
						"Pôle formation & insertion",
						"Pôle plaidoyer & droits humains",
						"Pôle communication & mobilisation",
						"Pôle projets & partenariats",
					],
				},
			],
		},
	],
} as const;
---

<Layout>
	<main class="bg-neutral-50 text-neutral-900">
		<!-- En-tête de page -->
		<div
			class="relative overflow-hidden border-b border-green-900/10 bg-linear-to-br from-green-900 via-green-800 to-emerald-950 px-4 py-14 text-white sm:px-6 lg:px-8"
		>
			<div
				class="pointer-events-none absolute -right-16 top-10 h-56 w-56 rounded-full bg-orange-400/15 blur-3xl"
				aria-hidden="true"
			>
			</div>
			<div
				class="pointer-events-none absolute -left-20 bottom-0 h-48 w-48 rounded-full bg-white/10 blur-3xl"
				aria-hidden="true"
			>
			</div>
			<div class="relative mx-auto max-w-7xl">
				<p class="text-sm font-medium uppercase tracking-widest text-green-200/90">
					Le mouvement
				</p>
				<h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
					À propos de LIJADCI
				</h1>
				<p class="mt-4 max-w-2xl text-base text-green-100/95 sm:text-lg">
					Mouvement citoyen pour la jeunesse ivoirienne : découvrez notre histoire, nos
					engagements et la façon dont nous travaillons ensemble.
				</p>
			</div>
		</div>

		<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
			<!-- Histoire -->
			<section class="lg:grid lg:grid-cols-12 lg:gap-12" aria-labelledby="histoire-title">
				<div class="lg:col-span-4">
					<h2
						id="histoire-title"
						class="text-2xl font-bold tracking-tight text-green-950 sm:text-3xl"
					>
						{histoire.title}
					</h2>
					<p class="mt-2 text-sm font-medium text-orange-700">
						Repères — texte à valider avant publication officielle
					</p>
				</div>
				<div class="mt-8 space-y-4 text-base leading-relaxed text-neutral-700 lg:col-span-8 lg:mt-0">
					{histoire.paragraphs.map((p) => <p>{p}</p>)}
				</div>
			</section>

			<!-- Mission & vision -->
			<section
				class="mt-16 grid gap-6 lg:mt-20 lg:grid-cols-2 lg:gap-8"
				aria-label="Mission et vision"
			>
				<div
					class="rounded-2xl border border-green-900/10 bg-white p-6 shadow-sm ring-1 ring-green-900/5 sm:p-8"
				>
					<h2 id="mission-title" class="text-xl font-bold text-green-950">
						{mission.title}
					</h2>
					<p class="mt-4 text-base leading-relaxed text-neutral-700">
						{mission.text}
					</p>
				</div>
				<div
					class="rounded-2xl border border-orange-200/80 bg-linear-to-br from-orange-50/80 to-white p-6 shadow-sm ring-1 ring-orange-900/10 sm:p-8"
				>
					<h2 id="vision-title" class="text-xl font-bold text-green-950">
						{vision.title}
					</h2>
					<p class="mt-4 text-base leading-relaxed text-neutral-700">
						{vision.text}
					</p>
				</div>
			</section>

			<!-- Valeurs -->
			<section class="mt-16 lg:mt-20" aria-labelledby="valeurs-title">
				<h2
					id="valeurs-title"
					class="text-2xl font-bold tracking-tight text-green-950 sm:text-3xl"
				>
					Nos valeurs
				</h2>
				<p class="mt-2 max-w-2xl text-neutral-600">
					Des principes qui guident nos actions au quotidien, sur le terrain et avec nos
					partenaires.
				</p>
				<ul
					class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3"
				>
					{
						valeurs.map(({ title, text }) => (
							<li>
								<article class="h-full rounded-2xl border border-green-900/10 bg-white p-6 shadow-sm transition hover:border-green-900/20 hover:shadow-md">
									<h3 class="text-lg font-semibold text-green-950">{title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-neutral-600">{text}</p>
								</article>
							</li>
						))
					}
				</ul>
			</section>

			<!-- Équipe -->
			<section class="mt-16 lg:mt-20" aria-labelledby="equipe-title">
				<h2
					id="equipe-title"
					class="text-2xl font-bold tracking-tight text-green-950 sm:text-3xl"
				>
					Équipe
				</h2>
				<p class="mt-2 max-w-2xl text-neutral-600">
					Structure indicative des responsabilités — identités, liens vers les profils
					sociaux et contacts seront publiés lorsque validés par le mouvement.
				</p>
				<ul class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
					{
						equipe.map(({ role, nom, detail, imageFile, socials }) => {
							const photo = resolveTeamImage(imageFile);
							const initials =
								nom
									.replace("À compléter", "")
									.split(/\s+/)
									.filter(Boolean)
									.slice(0, 2)
									.map((w) => w[0]?.toUpperCase() ?? "")
									.join("") || "…";
							const memberLabel =
								nom === "À compléter" ? role : `${nom} — ${role}`;
							return (
								<li>
									<article class="flex h-full flex-col rounded-2xl border border-green-900/10 bg-white p-6 text-center shadow-sm">
										<div class="mx-auto h-28 w-28 shrink-0 overflow-hidden rounded-full ring-2 ring-green-900/15 ring-offset-2 ring-offset-white">
											{photo ? (
												<Image
													src={photo}
													alt={
														nom === "À compléter"
															? `Photo du poste : ${role}`
															: `${nom} — ${role}`
													}
													class="h-full w-full object-cover"
													width={224}
													height={224}
													loading="lazy"
													decoding="async"
												/>
											) : (
												<div
													class="flex h-full w-full items-center justify-center bg-green-900 text-xl font-bold text-white"
													aria-hidden="true"
												>
													{initials}
												</div>
											)}
										</div>
										<h3 class="mt-4 text-sm font-semibold uppercase tracking-wide text-green-800">
											{role}
										</h3>
										<p class="mt-1 text-base font-medium text-green-950">{nom}</p>
										<p class="mt-3 grow text-left text-sm leading-relaxed text-neutral-600">
											{detail}
										</p>
										<TeamSocialLinks memberLabel={memberLabel} links={socials} />
									</article>
								</li>
							);
						})
					}
				</ul>
			</section>

			<!-- Organigramme -->
			<section
				class="mt-16 rounded-2xl border border-green-900/10 bg-white p-6 shadow-sm sm:p-8 lg:mt-20"
				aria-labelledby="org-title"
			>
				<h2
					id="org-title"
					class="text-2xl font-bold tracking-tight text-green-950 sm:text-3xl"
				>
					Organigramme
				</h2>
				<p class="mt-2 max-w-3xl text-neutral-600">
					{organigramme.intro}
				</p>

				<div class="mt-10 flex flex-col items-center">
					{
						organigramme.niveaux.map((root) => (
							<div class="flex w-full max-w-4xl flex-col items-center">
								<div class="w-full max-w-md rounded-xl border-2 border-green-900/25 bg-green-50/50 px-6 py-4 text-center">
									<p class="text-xs font-semibold uppercase tracking-wider text-green-800">
										{root.label}
									</p>
									<p class="mt-1 font-semibold text-green-950">{root.nom}</p>
								</div>
								<div
									class="h-8 w-px bg-green-900/25"
									aria-hidden="true"
								/>
								{root.enfants.map((child) => (
									<>
										<div class="w-full max-w-lg rounded-xl border border-green-900/15 bg-white px-6 py-4 text-center shadow-sm">
											<p class="text-xs font-semibold uppercase tracking-wider text-neutral-500">
												{child.label}
											</p>
											<p class="mt-1 font-semibold text-green-950">{child.nom}</p>
										</div>
										<div
											class="h-6 w-px bg-green-900/25"
											aria-hidden="true"
										/>
										<ul class="grid w-full gap-3 sm:grid-cols-2 lg:grid-cols-4">
											{child.enfants.map((pole) => (
												<li>
													<div class="rounded-lg border border-neutral-200 bg-neutral-50/80 px-3 py-3 text-center text-sm font-medium text-neutral-800">
														{pole}
													</div>
												</li>
											))}
										</ul>
									</>
								))}
							</div>
						))
					}
				</div>
			</section>

			<!-- CTA -->
			<section
				class="mt-16 flex flex-col items-start justify-between gap-6 rounded-2xl bg-linear-to-r from-green-900 to-emerald-900 px-6 py-8 text-white sm:flex-row sm:items-center sm:px-10 lg:mt-20"
				aria-labelledby="about-cta-title"
			>
				<div>
					<h2 id="about-cta-title" class="text-xl font-bold sm:text-2xl">
						Rejoindre ou soutenir LIJADCI
					</h2>
					<p class="mt-2 max-w-xl text-sm text-green-100 sm:text-base">
						Adhésion, don, partenariat : choisissez la démarche qui vous correspond.
					</p>
				</div>
				<div class="flex flex-wrap gap-3">
					<a
						href="/adhesion"
						class="inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-semibold text-green-900 shadow-sm transition hover:bg-green-50"
					>
						Adhérer
					</a>
					<a
						href="/contact"
						class="inline-flex items-center justify-center rounded-xl border border-white/40 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
					>
						Nous contacter
					</a>
				</div>
			</section>
		</div>
	</main>
</Layout>
