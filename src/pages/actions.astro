---
import Layout from "../layouts/Layout.astro";

/**
 * Contenu générique — à remplacer par les actions validées et sourcées.
 * Ne pas publier de résultats chiffrés sans données officielles.
 */
const intro = {
	lead:
		"LIJADCI déploie des actions concrètes pour la jeunesse ivoirienne : sur le terrain, en ligne et avec des partenaires, nous combinons formation, plaidoyer, projets et mobilisation citoyenne.",
	suite:
		"Les exemples ci-dessous illustrent nos axes d’intervention ; le détail des programmes, calendriers et bilans pourra être enrichi via le futur espace d’édition (CMS) ou des pages dédiées.",
};

const domaines = [
	{
		title: "Formation & montée en compétences",
		text: "Ateliers, séminaires et parcours visant l’employabilité, l’entrepreneuriat et la compréhension des enjeux publics.",
		icon: "formation",
	},
	{
		title: "Insertion socio-professionnelle",
		text: "Accompagnement vers l’emploi, l’auto-emploi et la structuration de petites initiatives locales.",
		icon: "insertion",
	},
	{
		title: "Entrepreneuriat & économie sociale",
		text: "Soutien aux idées de projet, mise en réseau et sensibilisation aux bonnes pratiques économiques responsables.",
		icon: "entreprise",
	},
	{
		title: "Droits humains & démocratie",
		text: "Sensibilisation aux libertés fondamentales, participation citoyenne et dialogue avec les institutions.",
		icon: "droits",
	},
	{
		title: "Cohésion sociale & éducation",
		text: "Actions de rapprochement entre communautés, vulgarisation et accès à l’information pour les jeunes.",
		icon: "cohesion",
	},
	{
		title: "Développement durable",
		text: "Prise en compte de l’environnement et de la résilience des territoires dans nos projets et campagnes.",
		icon: "durable",
	},
] as const;

const modalites = [
	{
		title: "Terrain & communautés",
		description:
			"Rencontres locales, groupes de travail et actions de proximité avec les associations et les autorités quand c’est pertinent.",
	},
	{
		title: "Événements & campagnes",
		description:
			"Forums, conférences, ateliers et temps forts de mobilisation — voir l’agenda pour les prochaines dates.",
	},
	{
		title: "Contenus & visibilité",
		description:
			"Articles, témoignages et relais sur les réseaux sociaux pour documenter les initiatives et élargir l’impact.",
	},
] as const;

const liensUtiles = [
	{ href: "/actualites", label: "Actualités", hint: "Retours d’actions et annonces" },
	{ href: "/evenements", label: "Événements", hint: "Inscriptions et agenda" },
	{ href: "/galerie", label: "Galerie", hint: "Photos et vidéos de terrain" },
	{ href: "/partenaires", label: "Partenaires", hint: "Coopérations en cours" },
] as const;
---

<Layout>
	<main class="bg-neutral-50 text-neutral-900">
		<div
			class="relative overflow-hidden border-b border-green-900/10 bg-linear-to-br from-green-900 via-green-800 to-emerald-950 px-4 py-14 text-white sm:px-6 lg:px-8"
		>
			<div
				class="pointer-events-none absolute -right-20 top-12 h-60 w-60 rounded-full bg-orange-400/20 blur-3xl"
				aria-hidden="true"
			>
			</div>
			<div
				class="pointer-events-none absolute -left-24 bottom-0 h-52 w-52 rounded-full bg-lime-300/10 blur-3xl"
				aria-hidden="true"
			>
			</div>
			<div class="relative mx-auto max-w-7xl">
				<p class="text-sm font-medium uppercase tracking-widest text-green-200/90">
					Agir avec LIJADCI
				</p>
				<h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
					Nos actions
				</h1>
				<p class="mt-4 max-w-2xl text-base text-green-100/95 sm:text-lg">
					Formation, plaidoyer, projets et mobilisation : découvrez comment le
					mouvement s’engage au service des jeunes et des territoires ivoiriens.
				</p>
			</div>
		</div>

		<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
			<section aria-labelledby="actions-intro">
				<h2 id="actions-intro" class="sr-only">Introduction</h2>
				<p class="max-w-3xl text-lg font-medium text-green-950">
					{intro.lead}
				</p>
				<p class="mt-4 max-w-3xl text-base leading-relaxed text-neutral-700">
					{intro.suite}
				</p>
			</section>

			<section class="mt-16 lg:mt-20" aria-labelledby="domaines-title">
				<h2
					id="domaines-title"
					class="text-2xl font-bold tracking-tight text-green-950 sm:text-3xl"
				>
					Domaines d’intervention
				</h2>
				<p class="mt-2 max-w-2xl text-neutral-600">
					Axes alignés sur les missions du mouvement : développement
					politique, économique et social, avec une attention constante à la
					jeunesse.
				</p>
				<ul class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
					{
						domaines.map(({ title, text, icon }) => (
							<li>
								<article class="flex h-full flex-col rounded-2xl border border-green-900/10 bg-white p-6 shadow-sm ring-1 ring-green-900/5 transition hover:border-green-900/20 hover:shadow-md">
									<div
										class="flex h-11 w-11 items-center justify-center rounded-xl bg-green-100 text-green-900"
										aria-hidden="true"
									>
										{icon === "formation" && (
											<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
											</svg>
										)}
										{icon === "insertion" && (
											<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.050-.732m.016 7.08a48.11 48.11 0 0 1-3.478-.397m4.002 0a5.518 5.518 0 0 0 3.478-.397m0 0a5.812 5.812 0 0 0 2.682-3.293m0 0a5.766 5.766 0 0 0-.09-3.473m0 0a5.724 5.724 0 0 0-2.241-2.546M16.5 14.25l-3.75-3.75M16.5 14.25l3.75-3.75M16.5 14.25v4.125c0 .621-.504 1.125-1.125 1.125H4.125c-.621 0-1.125-.504-1.125-1.125V11.25c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25v3.375z" />
											</svg>
										)}
										{icon === "entreprise" && (
											<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3.375 3h17.25c.621 0 1.125.504 1.125 1.125v20.25M3.375 3h-1.5A1.125 1.125 0 0 0 .75 4.125v15.75c0 .621.504 1.125 1.125 1.125h1.5m17.25-18h1.5c.621 0 1.125.504 1.125 1.125v15.75c0 .621-.504 1.125-1.125 1.125h-1.5m-17.25-18v18" />
											</svg>
										)}
										{icon === "droits" && (
											<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.34 0-4.29.282-6.294.843M18.75 4.97v11.03m0 0c-1.472 0-2.882.265-4.185.75M18.75 19.03v-1.06m0-11.97v1.06" />
											</svg>
										)}
										{icon === "cohesion" && (
											<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.09 9.09 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
											</svg>
										)}
										{icon === "durable" && (
											<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
											</svg>
										)}
									</div>
									<h3 class="mt-4 text-lg font-semibold text-green-950">{title}</h3>
									<p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-600">{text}</p>
								</article>
							</li>
						))
					}
				</ul>
			</section>

			<section
				class="mt-16 rounded-2xl border border-green-900/10 bg-white p-6 shadow-sm sm:p-8 lg:mt-20"
				aria-labelledby="modalites-title"
			>
				<h2
					id="modalites-title"
					class="text-xl font-bold text-green-950 sm:text-2xl"
				>
					Comment nos actions prennent forme
				</h2>
				<ul class="mt-8 grid gap-6 md:grid-cols-3">
					{
						modalites.map(({ title, description }) => (
							<li>
								<h3 class="font-semibold text-green-900">{title}</h3>
								<p class="mt-2 text-sm leading-relaxed text-neutral-600">{description}</p>
							</li>
						))
					}
				</ul>
			</section>

			<section class="mt-16 lg:mt-20" aria-labelledby="liens-title">
				<h2
					id="liens-title"
					class="text-2xl font-bold tracking-tight text-green-950 sm:text-3xl"
				>
					Aller plus loin
				</h2>
				<p class="mt-2 text-neutral-600">
					Retrouvez le détail des activités au fil de l’eau sur ces pages.
				</p>
				<ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
					{
						liensUtiles.map(({ href, label, hint }) => (
							<li>
								<a
									href={href}
									class="flex h-full flex-col rounded-2xl border border-green-900/10 bg-white p-5 shadow-sm transition hover:border-green-900/25 hover:shadow-md focus-visible:outline focus-visible:ring-2 focus-visible:ring-green-900"
								>
									<span class="font-semibold text-green-950">{label}</span>
									<span class="mt-1 text-sm text-neutral-600">{hint}</span>
									<span class="mt-3 text-sm font-medium text-green-800">Voir →</span>
								</a>
							</li>
						))
					}
				</ul>
			</section>

			<section
				class="mt-16 flex flex-col items-start justify-between gap-6 rounded-2xl bg-linear-to-r from-green-900 to-emerald-900 px-6 py-8 text-white sm:flex-row sm:items-center sm:px-10 lg:mt-20"
				aria-labelledby="actions-cta"
			>
				<div>
					<h2 id="actions-cta" class="text-xl font-bold sm:text-2xl">
						Participer ou soutenir nos actions
					</h2>
					<p class="mt-2 max-w-xl text-sm text-green-100 sm:text-base">
						Rejoignez le mouvement, proposez un partenariat ou écrivez-nous pour en
						savoir plus.
					</p>
				</div>
				<div class="flex flex-wrap gap-3">
					<a
						href="/adhesion"
						class="inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-semibold text-green-900 shadow-sm transition hover:bg-green-50"
					>
						Adhérer
					</a>
					<a
						href="/partenaires"
						class="inline-flex items-center justify-center rounded-xl border border-white/40 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
					>
						Partenaires
					</a>
					<a
						href="/contact"
						class="inline-flex items-center justify-center rounded-xl border border-white/40 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
					>
						Contact
					</a>
				</div>
			</section>
		</div>
	</main>
</Layout>
