---
import Layout from "../layouts/Layout.astro";

/**
 * URL publique du PDF dans `public/` (ex. "/fiche-adhesion.pdf").
 * Chaîne vide = message « bientôt disponible » (évite un lien cassé).
 */
const ficheAdhesionUrl = "";

/**
 * Endpoint d’envoi (Formspree, API interne, etc.) — dédié aux demandes d’adhésion.
 * À connecter au même backend que le contact ou à un formulaire séparé.
 */
const FORM_ENDPOINT = "https://formspree.io/f/VOTRE_ID_ADHESION";

const etapes = [
	{
		title: "1. Formulaire en ligne",
		text: "Renseignez vos coordonnées et votre motivation pour rejoindre le mouvement.",
	},
	{
		title: "2. Fiche (facultatif)",
		text: "Vous pouvez compléter la fiche PDF et la transmettre selon les consignes indiquées par l’équipe.",
	},
	{
		title: "3. Validation",
		text: "Les demandes sont revues par l’équipe ; vous serez recontacté·e pour la suite du processus.",
	},
] as const;

const inputClass =
	"mt-1.5 w-full rounded-xl border border-neutral-200 bg-neutral-50/80 px-4 py-3 text-neutral-900 outline-none ring-green-900/20 transition placeholder:text-neutral-400 focus:border-green-800 focus:bg-white focus:ring-2";

const labelClass = "block text-sm font-medium text-neutral-800";
---

<Layout>
	<main class="bg-neutral-50 text-neutral-900">
		<div
			class="border-b border-green-900/10 bg-linear-to-br from-green-900 via-green-800 to-green-950 px-4 py-14 text-white sm:px-6 lg:px-8"
		>
			<div class="mx-auto max-w-7xl">
				<p class="text-sm font-medium uppercase tracking-widest text-green-200/90">
					Rejoindre LIJADCI
				</p>
				<h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
					Adhésion
				</h1>
				<p class="mt-4 max-w-2xl text-base text-green-100/95 sm:text-lg">
					Devenez membre du mouvement : remplissez le formulaire ci-dessous. Les
					demandes sont traitées par l’équipe avant validation définitive.
				</p>
			</div>
		</div>

		<div
			class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:grid lg:grid-cols-12 lg:gap-10 lg:px-8 lg:py-16"
		>
			<div class="lg:col-span-5">
				<section aria-labelledby="adhesion-intro">
					<h2 id="adhesion-intro" class="text-xl font-bold text-green-950">
						Pourquoi adhérer ?
					</h2>
					<p class="mt-3 text-base leading-relaxed text-neutral-700">
						L’adhésion permet de participer aux actions du mouvement, d’accéder à
						certains espaces de travail et de soutenir nos initiatives en Côte
						d’Ivoire et au-delà.
					</p>
				</section>

				<section class="mt-10" aria-labelledby="adhesion-etapes">
					<h2 id="adhesion-etapes" class="text-lg font-semibold text-green-900">
						Démarche
					</h2>
					<ol class="mt-4 space-y-4">
						{
							etapes.map(({ title, text }) => (
								<li class="flex gap-3">
									<span
										class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-green-100 text-xs font-bold text-green-900"
										aria-hidden="true"
									>
										{title.slice(0, 1)}
									</span>
									<div>
										<p class="font-semibold text-green-950">{title}</p>
										<p class="mt-1 text-sm leading-relaxed text-neutral-600">
											{text}
										</p>
									</div>
								</li>
							))
						}
					</ol>
				</section>

				<section
					class="mt-10 rounded-2xl border border-green-900/15 bg-white p-6 shadow-sm ring-1 ring-green-900/5"
					aria-labelledby="fiche-title"
				>
					<h2 id="fiche-title" class="text-lg font-semibold text-green-900">
						Fiche d’adhésion
					</h2>
					<p class="mt-2 text-sm leading-relaxed text-neutral-600">
						Téléchargez la fiche pour une inscription sur support papier ou pour
						conserver une copie de vos engagements.
					</p>
					{
						ficheAdhesionUrl ? (
							<a
								href={ficheAdhesionUrl}
								class="mt-4 inline-flex items-center gap-2 rounded-xl border border-green-900/20 bg-green-50 px-4 py-3 text-sm font-semibold text-green-900 transition hover:border-green-900/35 hover:bg-green-100 focus-visible:outline focus-visible:ring-2 focus-visible:ring-green-900 focus-visible:ring-offset-2"
								download
							>
								<svg
									class="h-5 w-5 shrink-0"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									viewBox="0 0 24 24"
									aria-hidden="true"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
									/>
								</svg>
								Télécharger le PDF
							</a>
						) : (
							<p class="mt-4 text-sm italic text-neutral-500">
								Document en cours de publication — revenez bientôt ou contactez-nous.
							</p>
						)
					}
				</section>

				<p class="mt-8 text-sm text-neutral-600">
					Une question ?
					<a
						href="/contact"
						class="font-semibold text-green-800 underline decoration-green-800/30 underline-offset-2 hover:decoration-green-800"
					>
						Contactez-nous
					</a>
					.
				</p>
			</div>

			<div class="mt-12 lg:col-span-7 lg:mt-0">
				<div
					class="rounded-2xl border border-green-900/10 bg-white p-6 shadow-sm sm:p-8"
				>
					<h2 class="text-lg font-semibold text-green-900">
						Formulaire de demande d’adhésion
					</h2>
					<p class="mt-1 text-sm text-neutral-600">
						Les champs marqués d’un astérisque (*) sont obligatoires.
					</p>

					<form class="mt-6 space-y-5" action={FORM_ENDPOINT} method="POST">
						<input type="hidden" name="_subject" value="Nouvelle demande d’adhésion — LIJADCI" />
						<p class="sr-only">
							<label>
								Ne pas remplir ce champ
								<input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
							</label>
						</p>

						<div class="grid gap-5 sm:grid-cols-2">
							<div>
								<label for="adhesion-prenom" class={labelClass}>
									Prénom <span class="text-red-600">*</span>
								</label>
								<input
									id="adhesion-prenom"
									name="prenom"
									type="text"
									autocomplete="given-name"
									required
									class={inputClass}
									placeholder="Prénom"
								/>
							</div>
							<div>
								<label for="adhesion-nom" class={labelClass}>
									Nom <span class="text-red-600">*</span>
								</label>
								<input
									id="adhesion-nom"
									name="nom"
									type="text"
									autocomplete="family-name"
									required
									class={inputClass}
									placeholder="Nom"
								/>
							</div>
							<div>
								<label for="adhesion-telephone" class={labelClass}>
									Téléphone <span class="text-red-600">*</span>
								</label>
								<input
									id="adhesion-telephone"
									name="telephone"
									type="tel"
									autocomplete="tel"
									required
									class={inputClass}
									placeholder="+225 …"
								/>
							</div>
							<div>
								<label for="adhesion-email" class={labelClass}>
									E-mail <span class="text-red-600">*</span>
								</label>
								<input
									id="adhesion-email"
									name="email"
									type="email"
									autocomplete="email"
									required
									class={inputClass}
									placeholder="vous@exemple.com"
								/>
							</div>
							<div class="sm:col-span-2">
								<label for="adhesion-ville" class={labelClass}>
									Ville / localisation <span class="text-red-600">*</span>
								</label>
								<input
									id="adhesion-ville"
									name="ville"
									type="text"
									autocomplete="address-level2"
									required
									class={inputClass}
									placeholder="Ex. Abidjan, Bouaké…"
								/>
							</div>
							<div class="sm:col-span-2">
								<label for="adhesion-profession" class={labelClass}>
									Profession / activité
								</label>
								<input
									id="adhesion-profession"
									name="profession"
									type="text"
									autocomplete="organization-title"
									class={inputClass}
									placeholder="Étudiant·e, entrepreneur·e, salarié·e…"
								/>
							</div>
							<div class="sm:col-span-2">
								<label for="adhesion-motivation" class={labelClass}>
									Motivation <span class="text-red-600">*</span>
								</label>
								<textarea
									id="adhesion-motivation"
									name="motivation"
									rows="5"
									required
									class={`${inputClass} resize-y`}
									placeholder="Pourquoi souhaitez-vous rejoindre LIJADCI ? Quelles compétences ou envies souhaitez-vous mettre au service du mouvement ?"
								></textarea>
							</div>
						</div>

						<p class="text-xs text-neutral-500">
							Vos données sont transmises de façon sécurisée. Elles servent uniquement
							au traitement de votre demande d’adhésion et à vous recontacter. Une
							<strong>validation par l’équipe</strong> est nécessaire avant toute
							adhésion effective.
						</p>

						<button
							type="submit"
							class="inline-flex w-full items-center justify-center rounded-xl bg-green-900 px-5 py-3.5 text-sm font-semibold text-white shadow-sm transition hover:bg-green-800 focus-visible:outline focus-visible:ring-2 focus-visible:ring-green-900 focus-visible:ring-offset-2 sm:w-auto"
						>
							Envoyer ma demande
						</button>
					</form>
				</div>
			</div>
		</div>
	</main>
</Layout>
