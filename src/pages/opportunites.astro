---
import Layout from "../layouts/Layout.astro";
import {
	labelOpportuniteCategorie,
	opportunites,
	type OpportuniteCategorie,
} from "../data/opportunites";

const categories: OpportuniteCategorie[] = [
	"formation",
	"stage",
	"emploi",
	"appel",
	"concours",
];

const badgeClass: Record<OpportuniteCategorie, string> = {
	formation: "bg-emerald-100 text-emerald-900 ring-emerald-600/20",
	stage: "bg-sky-100 text-sky-900 ring-sky-600/20",
	emploi: "bg-amber-100 text-amber-950 ring-amber-600/25",
	appel: "bg-violet-100 text-violet-900 ring-violet-600/20",
	concours: "bg-orange-100 text-orange-950 ring-orange-600/25",
};
---

<Layout>
	<main class="bg-neutral-50 text-neutral-900">
		<div
			class="relative overflow-hidden border-b border-green-900/10 bg-linear-to-br from-green-900 via-green-800 to-emerald-950 px-4 py-14 text-white sm:px-6 lg:px-8"
		>
			<div
				class="pointer-events-none absolute -left-20 top-1/2 h-48 w-48 -translate-y-1/2 rounded-full bg-lime-300/15 blur-3xl"
				aria-hidden="true"
			>
			</div>
			<div class="relative mx-auto max-w-7xl">
				<p class="text-sm font-medium uppercase tracking-widest text-green-200/90">
					Carrières & apprentissages
				</p>
				<h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
					Opportunités
				</h1>
				<p class="mt-4 max-w-2xl text-base text-green-100/95 sm:text-lg">
					Formations, stages, emplois, appels à candidatures et concours : les offres
					liées au mouvement et à ses partenaires.
				</p>
			</div>
		</div>

		<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
			<section class="max-w-3xl" aria-labelledby="opp-intro">
				<h2 id="opp-intro" class="sr-only">Introduction</h2>
				<p class="text-lg font-medium text-green-950">
					Vous cherchez à vous engager, à apprendre ou à candidater ? Retrouvez ici des
					parcours indicatifs — les fiches détaillées et dates limites seront affinées
					selon les procédures réelles.
				</p>
				<p class="mt-4 text-base leading-relaxed text-neutral-700">
					Pour toute question ou envoi de dossier, utilisez la page contact en précisant
					l’intitulé de l’opportunité.
				</p>
			</section>

			<nav
				class="mt-10 flex flex-wrap gap-2"
				aria-label="Types d’opportunités sur cette page"
			>
				{
					categories.map((cat) => (
						<a
							href={`#opp-${cat}`}
							class="rounded-full border border-green-900/15 bg-white px-3 py-1.5 text-xs font-semibold text-green-900 shadow-sm transition hover:border-green-900/30 hover:bg-green-50"
						>
							{labelOpportuniteCategorie(cat)}
						</a>
					))
				}
			</nav>

			{
				categories.map((cat) => {
					const list = opportunites.filter((o) => o.categorie === cat);
					return (
						<section
							class="mt-14 scroll-mt-24 lg:scroll-mt-28"
							id={`opp-${cat}`}
							aria-labelledby={`opp-h-${cat}`}
						>
							<h2
								id={`opp-h-${cat}`}
								class="flex flex-wrap items-center gap-3 text-xl font-bold text-green-950 sm:text-2xl"
							>
								{labelOpportuniteCategorie(cat)}
								<span
									class:list={[
										"rounded-full px-2.5 py-0.5 text-xs font-semibold ring-1",
										badgeClass[cat],
									]}
								>
									{list.length}
								</span>
							</h2>
							{list.length === 0 ? (
								<p class="mt-4 text-sm text-neutral-500">Aucune offre dans cette catégorie pour l’instant.</p>
							) : (
								<ul class="mt-6 grid gap-5 md:grid-cols-2">
									{list.map((opp) => (
										<li>
											<article class="flex h-full flex-col rounded-2xl border border-green-900/10 bg-white p-6 shadow-sm transition hover:border-green-900/20 hover:shadow-md">
												<h3 class="text-lg font-semibold text-green-950">{opp.title}</h3>
												{opp.organisme ? (
													<p class="mt-1 text-sm text-neutral-500">{opp.organisme}</p>
												) : null}
												{opp.deadline ? (
													<p class="mt-3 text-sm font-medium text-green-800">
														Clôture :{" "}
														{opp.deadlineIso ? (
															<time datetime={opp.deadlineIso}>{opp.deadline}</time>
														) : (
															opp.deadline
														)}
													</p>
												) : null}
												<p class="mt-3 flex-1 text-sm leading-relaxed text-neutral-600">
													{opp.excerpt}
												</p>
												<div class="mt-5">
													{opp.href ? (
														<a
															href={opp.href}
															class="inline-flex rounded-xl bg-green-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-green-800"
														>
															Candidater / Infos
														</a>
													) : (
														<a
															href="/contact"
															class="inline-flex rounded-xl border border-green-900/25 px-4 py-2.5 text-sm font-semibold text-green-900 transition hover:bg-green-50"
														>
															Nous contacter
														</a>
													)}
												</div>
											</article>
										</li>
									))}
								</ul>
							)}
						</section>
					);
				})
			}
		</div>
	</main>
</Layout>
