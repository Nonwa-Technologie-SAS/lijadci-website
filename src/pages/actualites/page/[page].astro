---
import Layout from "../../../layouts/Layout.astro";
import ActualiteListItem from "../../../components/actualites/ActualiteListItem.astro";
import ActualitesPagination from "../../../components/actualites/ActualitesPagination.astro";
import {
	getSortedActualites,
	getActualitesTotalPages,
	getActualitesPageSlice,
} from "../../../lib/actualites-list";

export function getStaticPaths() {
	const sorted = getSortedActualites();
	const total = getActualitesTotalPages(sorted);
	if (total <= 1) return [];
	const paths: { params: { page: string } }[] = [];
	for (let p = 2; p <= total; p++) {
		paths.push({ params: { page: String(p) } });
	}
	return paths;
}

const { page } = Astro.params;
const pageNum = parseInt(page ?? "", 10);
const sorted = getSortedActualites();
const totalPages = getActualitesTotalPages(sorted);

if (Number.isNaN(pageNum) || pageNum < 2 || pageNum > totalPages) {
	return Astro.redirect("/actualites");
}

const items = getActualitesPageSlice(sorted, pageNum);
---

<Layout>
	<main class="bg-neutral-50 text-neutral-900">
		<div
			class="border-b border-green-900/10 bg-linear-to-br from-green-900 via-green-800 to-green-950 px-4 py-14 text-white sm:px-6 lg:px-8"
		>
			<div class="mx-auto max-w-7xl">
				<p class="text-sm font-medium uppercase tracking-widest text-green-200/90">
					Infos & terrain
				</p>
				<h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
					Actualités
				</h1>
				<p class="mt-4 max-w-2xl text-base text-green-100/95 sm:text-lg">
					Suivez les annonces, retours d’actions et perspectives du mouvement. Le
					contenu pourra être enrichi via le futur espace d’édition (CMS).
				</p>
				<p class="mt-3 text-sm font-medium text-green-200/90">
					Page {pageNum} sur {totalPages}
				</p>
			</div>
		</div>

		<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
			{
				items.length === 0 ? (
					<p class="rounded-2xl border border-green-900/10 bg-white p-8 text-center text-neutral-600">
						Aucun article sur cette page.
					</p>
				) : (
					<ul class="grid gap-8 lg:grid-cols-1">
						{items.map((article) => (
							<ActualiteListItem article={article} />
						))}
					</ul>
				)
			}
			<ActualitesPagination currentPage={pageNum} totalPages={totalPages} />
		</div>
	</main>
</Layout>
